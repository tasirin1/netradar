<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E0F2F1"
    android:orientation="vertical"
    android:padding="12dp">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- ═══ Header ═══ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardElevation="2dp"
                app:cardCornerRadius="14dp"
                app:strokeWidth="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#00695C"
                    android:gravity="center"
                    android:padding="12dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="NetScan"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="1dp"
                            android:text="Enter IP / URL / CIDR below"
                            android:textColor="#80CBC4"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ═══ TARGET INPUT ═══ SIMPLE & BIG ═══ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:cardElevation="1dp"
                app:cardCornerRadius="10dp"
                app:strokeColor="#00695C"
                app:strokeWidth="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Target"
                        android:textColor="#000000"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                    <EditText
                        android:id="@+id/inputTarget"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="4dp"
                        android:background="#FFFFFF"
                        android:padding="10dp"
                        android:textSize="15sp"
                        android:textColor="#000000"
                        android:singleLine="true"
                        android:hint="e.g. 192.168.0.1, 10.0.0.0/24, barayacell.com"
                        android:text="192.168.0.0/24"
                        android:inputType="textUri" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ═══ PRESETS (PRE-FILL BUTTONS) ═══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal"
                android:weightSum="4">
                <TextView
                    android:id="@+id/preLocal"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="3dp"
                    android:gravity="center"
                    android:background="@drawable/btn_preset"
                    android:clickable="true"
                    android:focusable="true"
                    android:text="192.168.0.0/24"
                    android:textColor="#00695C"
                    android:textSize="10sp" />
                <TextView
                    android:id="@+id/preRouter"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_weight="1"
                    android:layout_marginStart="3dp"
                    android:layout_marginEnd="3dp"
                    android:gravity="center"
                    android:background="@drawable/btn_preset"
                    android:clickable="true"
                    android:focusable="true"
                    android:text="192.168.0.1"
                    android:textColor="#00695C"
                    android:textSize="10sp" />
                <TextView
                    android:id="@+id/preWan"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_weight="1"
                    android:layout_marginStart="3dp"
                    android:layout_marginEnd="3dp"
                    android:gravity="center"
                    android:background="@drawable/btn_preset"
                    android:clickable="true"
                    android:focusable="true"
                    android:text="157.66.50.147"
                    android:textColor="#00695C"
                    android:textSize="10sp" />
                <TextView
                    android:id="@+id/preHost"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_weight="1"
                    android:layout_marginStart="3dp"
                    android:gravity="center"
                    android:background="@drawable/btn_preset"
                    android:clickable="true"
                    android:focusable="true"
                    android:text="barayacell.com"
                    android:textColor="#00695C"
                    android:textSize="10sp" />
            </LinearLayout>

            <!-- ═══ SCAN BUTTONS ═══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:weightSum="3">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnQuick"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="3dp"
                    android:backgroundTint="#00695C"
                    android:text="Quick"
                    android:textAllCaps="false"
                    android:textSize="13sp" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFull"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:layout_marginStart="3dp"
                    android:layout_marginEnd="3dp"
                    android:backgroundTint="#00897B"
                    android:text="Full"
                    android:textAllCaps="false"
                    android:textSize="13sp" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnNmap"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:layout_marginStart="3dp"
                    android:backgroundTint="#004D40"
                    android:text="Nmap"
                    android:textAllCaps="false"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- ═══ STATUS ═══ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardElevation="0dp"
                app:cardCornerRadius="8dp"
                app:strokeColor="#B2DFDB"
                app:strokeWidth="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="8dp">
                    <View
                        android:id="@+id/dotStatus"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="#BDBDBD"
                        android:layout_marginEnd="8dp" />
                    <TextView
                        android:id="@+id/tvStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Ready"
                        android:textColor="#455A64"
                        android:textSize="12sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ═══ RESULTS ═══ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardResults"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:minHeight="240dp"
                android:layout_marginTop="8dp"
                android:visibility="visible"
                app:cardElevation="0dp"
                app:cardCornerRadius="12dp"
                app:strokeColor="#B2DFDB"
                app:strokeWidth="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="12dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Results"
                            android:textColor="#000000"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnClear"
                            android:layout_width="wrap_content"
                            android:layout_height="28dp"
                            android:backgroundTint="#E0E0E0"
                            android:text="Clear"
                            android:textAllCaps="false"
                            android:textColor="#555"
                            android:textSize="12sp" />
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCopy"
                            android:layout_width="wrap_content"
                            android:layout_height="28dp"
                            android:layout_marginStart="4dp"
                            android:backgroundTint="#B2DFDB"
                            android:text="Copy"
                            android:textAllCaps="false"
                            android:textColor="#004D40"
                            android:textSize="12sp" />
                    </LinearLayout>
                    <TextView
                        android:id="@+id/tvSummary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="#455A64"
                        android:textSize="12sp" />
                    <TextView
                        android:id="@+id/tvResults"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:verticalScrollbarEnabled="true"
                        android:scrollbars="vertical"
                        android:layout_marginTop="4dp"
                        android:fontFamily="monospace"
                        android:lineSpacingExtra="2dp"
                        android:textColor="#000000"
                        android:textSize="12sp"
                        android:textIsSelectable="true"
                        android:visibility="visible" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:text="NetScan v1.1"
                android:textColor="#B2DFDB"
                android:textSize="10sp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
